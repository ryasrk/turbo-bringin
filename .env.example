# ── Tenrary-X Environment Configuration ─────────────────────────
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# Inference server port (llama-server binds here)
INFERENCE_PORT=18080

# Control/manager API port
CONTROL_PORT=3002

# Dashboard dev server port
DASHBOARD_PORT=3000

# Dashboard origin for CORS (used by manager.js)
DASHBOARD_ORIGIN=http://localhost:3000

# Optional: API key for control endpoints (leave empty to allow localhost-only)
CONTROL_API_KEY=
