# ── Tenrary-X Environment Configuration ─────────────────────────
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# Inference server port (llama-server binds here)
INFERENCE_PORT=18080

# Control/manager API port
CONTROL_PORT=3002

# Dashboard dev server port
DASHBOARD_PORT=3000

# Dashboard origin for CORS (used by manager.js)
DASHBOARD_ORIGIN=http://localhost:3000

# Optional: API key for control endpoints (leave empty to allow localhost-only)
CONTROL_API_KEY=

# EnowxAI provider configuration
ENOWXAI_BASE_URL=http://172.27.160.1:1430/v1
ENOWXAI_API_KEY=
ENOWXAI_MODEL=claude-opus-4.6

# Redis cache for provider request coalescing/caching
REDIS_URL=redis://127.0.0.1:6379

# Frontend-visible default provider model
VITE_ENOWXAI_DEFAULT_MODEL=claude-opus-4.6

# Ngrok tunnel for remote access (used by run_all_ngrok.sh)
# Get your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Static domain from: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=
